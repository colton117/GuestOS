generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Guest {
  id           String            @id @default(cuid())
  firstName    String
  lastName     String
  email        String            @unique
  phone        String            @unique
  smsOptIn     Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  vehicles     Vehicle[]
  visits       Visit[]
  credentials  GuestCredential[]
  loginCodes   GuestLoginCode[]
  activityLogs ActivityLog[]
}

model ActivityLog {
  id        String   @id @default(cuid())
  guestId   String
  message   String
  createdAt DateTime @default(now())
  guest     Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@index([guestId])
}

// Host/admin action audit trail + system/error events (Home Assistant,
// access attempts). Not tied to a Guest via foreign key since system events
// (e.g. an HA auth failure) aren't guest-scoped, and host/admin actions
// don't have a stable actor identity yet — see project_auth_gap-style notes
// on the single shared host password (no per-host login).
model SystemLog {
  id        String    @id @default(cuid())
  level     LogLevel  @default(INFO)
  category  String
  message   String
  actor     String?
  metadata  Json?
  createdAt DateTime  @default(now())

  @@index([category])
  @@index([createdAt])
}

enum LogLevel {
  INFO
  WARN
  ERROR
}

model GuestLoginCode {
  id         String    @id @default(cuid())
  guestId    String
  codeHash   String
  salt       String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  guest      Guest     @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@index([guestId])
}

model GuestCredential {
  id           String    @id @default(cuid())
  guestId      String
  credentialId String    @unique
  publicKey    Bytes
  counter      Int       @default(0)
  transports   String?
  deviceLabel  String?
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?
  guest        Guest     @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@index([guestId])
}

model Host {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ParkingSettings {
  id                        Int      @id @default(1)
  currentQuarterlyPromoCode String?
  parkingEnabled            Boolean  @default(true)
  maximumParkingDuration    Int      @default(7)
  updatedAt                 DateTime @updatedAt
}

model HomeAssistantSettings {
  id             Int      @id @default(1)
  haUrl          String?
  haToken        String?
  webhookTimeout Int      @default(10)
  updatedAt      DateTime @updatedAt
}

model NotificationSettings {
  id                      Int      @id @default(1)
  hostEmail               String?
  appleNotificationEnabled Boolean  @default(false)
  guestEmailEnabled       Boolean  @default(false)
  updatedAt               DateTime @updatedAt
}

model BrandingSettings {
  id            Int      @id @default(1)
  logoData      Bytes?
  logoMimeType  String?
  welcomeMessage String?
  primaryColor  String?
  accentColor   String?
  updatedAt     DateTime @updatedAt
}

model Door {
  id                    String    @id @default(cuid())
  friendlyName          String
  homeAssistantAction   String
  enabled               Boolean   @default(true)
  doorType              DoorType
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Vehicle {
  id        String @id @default(cuid())
  guestId   String
  make      String
  model     String
  year      Int
  color     String
  plate     String
  state     String
  isDefault Boolean @default(false)
  guest     Guest  @relation(fields: [guestId], references: [id], onDelete: Cascade)
  visits    Visit[]

  @@index([guestId])
}

model Visit {
  id                       String      @id @default(cuid())
  guestId                  String
  vehicleId                String?
  arrivalDateTime          DateTime
  departureDateTime        DateTime?
  parkingRequired          Boolean     @default(true)
  buildingAccessRequired   Boolean     @default(true)
  apartmentAccessRequired  Boolean     @default(true)
  requestNotes             String?
  status                   VisitStatus @default(PENDING)
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt
  guest                    Guest       @relation(fields: [guestId], references: [id], onDelete: Cascade)
  vehicle                  Vehicle?    @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([guestId])
  @@index([vehicleId])
  @@index([status])
}

enum VisitStatus {
  PENDING
  APPROVED
  DENIED
  ACTIVE
  COMPLETED
}

enum DoorType {
  BUTTERFLY
  SMARTRENT
  MANUAL_CODE
}
