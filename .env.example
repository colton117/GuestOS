DATABASE_URL="postgresql://guestos:<password>@100.77.184.10:5432/guestos?connection_limit=5"

# Host login (residents) — protects /host, /guests, /quick-register,
# /requests, /settings. This is the day-to-day resident/property host surface.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Admin login (you, the developer/operator) — protects /admin, /admin/hosts,
# /admin/property. This is the future multi-property operator console: adding
# hosts, and managing property-level config (Home Assistant, doors,
# notifications, branding). Reuses ADMIN_SESSION_SECRET to sign its session
# cookie unless SUPERADMIN_SESSION_SECRET is set below.
SUPERADMIN_PASSWORD=
SUPERADMIN_SESSION_SECRET=

# Home Assistant integration
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=

# Optional Home Assistant action routing
HOME_ASSISTANT_APPROVE_VISIT_DOMAIN=
HOME_ASSISTANT_APPROVE_VISIT_SERVICE=
HOME_ASSISTANT_APPROVE_VISIT_DATA_JSON=
HOME_ASSISTANT_APPROVE_VISIT_ENABLED=

HOME_ASSISTANT_DENY_VISIT_DOMAIN=
HOME_ASSISTANT_DENY_VISIT_SERVICE=
HOME_ASSISTANT_DENY_VISIT_DATA_JSON=
HOME_ASSISTANT_DENY_VISIT_ENABLED=

HOME_ASSISTANT_OPEN_GATE_DOMAIN=
HOME_ASSISTANT_OPEN_GATE_SERVICE=
HOME_ASSISTANT_OPEN_GATE_DATA_JSON=
HOME_ASSISTANT_OPEN_GATE_ENABLED=

HOME_ASSISTANT_CLOSE_GATE_DOMAIN=
HOME_ASSISTANT_CLOSE_GATE_SERVICE=
HOME_ASSISTANT_CLOSE_GATE_DATA_JSON=
HOME_ASSISTANT_CLOSE_GATE_ENABLED=

HOME_ASSISTANT_UNLOCK_DOOR_DOMAIN=
HOME_ASSISTANT_UNLOCK_DOOR_SERVICE=
HOME_ASSISTANT_UNLOCK_DOOR_DATA_JSON=
HOME_ASSISTANT_UNLOCK_DOOR_ENABLED=

HOME_ASSISTANT_LOCK_DOOR_DOMAIN=
HOME_ASSISTANT_LOCK_DOOR_SERVICE=
HOME_ASSISTANT_LOCK_DOOR_DATA_JSON=
HOME_ASSISTANT_LOCK_DOOR_ENABLED=

HOME_ASSISTANT_TOGGLE_HELPER_DOMAIN=
HOME_ASSISTANT_TOGGLE_HELPER_SERVICE=
HOME_ASSISTANT_TOGGLE_HELPER_DATA_JSON=
HOME_ASSISTANT_TOGGLE_HELPER_ENABLED=

HOME_ASSISTANT_RUN_SCRIPT_DOMAIN=
HOME_ASSISTANT_RUN_SCRIPT_SERVICE=
HOME_ASSISTANT_RUN_SCRIPT_DATA_JSON=
HOME_ASSISTANT_RUN_SCRIPT_ENABLED=

HOME_ASSISTANT_TRIGGER_AUTOMATION_DOMAIN=
HOME_ASSISTANT_TRIGGER_AUTOMATION_SERVICE=
HOME_ASSISTANT_TRIGGER_AUTOMATION_DATA_JSON=
HOME_ASSISTANT_TRIGGER_AUTOMATION_ENABLED=

# Guest passkey (WebAuthn) sign-in
# Optional — the RP ID/origin are derived from the request host by default, which
# works for both localhost dev and guest.minterav.com. Only set these if the app
# ever sits behind a proxy that obscures the real host.
WEBAUTHN_RP_ID=
WEBAUTHN_ORIGIN=

# Cloudflare Tunnel
# Set these when you want to run the app behind guest.minterav.com via Docker Compose.
CLOUDFLARED_TUNNEL_ID=
CLOUDFLARED_CREDENTIALS_FILE=
